{
  "name": "@fiveclaww/protocol",
  "version": "0.1.0",
  "description": "Open standard for verifiable agent work, identity, reputation, and machine-to-machine settlement primitives.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "spec",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "example": "npm run build && node dist/examples/simple-agent.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "agents",
    "proof-of-labor",
    "reputation",
    "escrow",
    "fiveclaww"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/ed25519": "^1.7.3",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
