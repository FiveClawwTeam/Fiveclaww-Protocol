{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fiveclaww.dev/schemas/identity/v1",
  "title": "AgentIdentity",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "did", "verification_methods"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "fiveclaww.identity.v1"
    },
    "did": {
      "type": "string",
      "pattern": "^did:fiveclaww:[1-9A-HJ-NP-Za-km-z]{32,44}$"
    },
    "display_name": {
      "type": "string",
      "maxLength": 128
    },
    "verification_methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "public_key_b58"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["Ed25519VerificationKey2020"]
          },
          "public_key_b58": {
            "type": "string",
            "minLength": 32
          }
        }
      }
    }
  }
}
